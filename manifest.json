{
  "manifest_version": 3,
  "name": "QuickCopy - Clipboard Snippets",
  "description": "Guarda y copia textos rápidamente al portapapeles con un clic",
  "version": "3.0.0",
  "permissions": [
    "storage",
    "clipboardWrite",
    "sidePanel",
    "tabs"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "QuickCopy"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}