{
  "manifest_version": 3,
  "name": "QuickCopy - Clipboard Snippets",
  "description": "Guarda y copia textos rapidamente al portapapeles con un clic.",
  "version": "3.2.0",
  "permissions": [
    "storage",
    "clipboardWrite",
    "sidePanel",
    "tabs"
  ],
  "action": {
    "default_title": "QuickCopy"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
